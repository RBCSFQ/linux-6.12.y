/dts-v1/;
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/phy/phy.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include "rk3528.dtsi"

/ {
	model = "Rockchip RK3528 W132D";
	compatible = "rockchip,rk3528-w132d", "rockchip,rk3528";

	aliases {
		ethernet0 = &gmac0;
		mmc0 = &sdmmc;
		mmc1 = &sdhci;
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:1500000n8";
		bootargs = "earlycon=uart8250,mmio32,0xff9f0000 console=ttyS0,1500000";
	};

	vcc5v0_sys: vcc5v0-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
	};

	vcc5v0_host: vcc5v0-host {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_host";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		enable-active-high;
		gpio = <&gpio4 RK_PC2 GPIO_ACTIVE_HIGH>;
		vin-supply = <&vcc5v0_sys>;
		pinctrl-names = "default";
		pinctrl-0 = <&vcc5v0_host_en>;
	};

	vcc_3v3_s3: vcc-3v3-s3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3_s3";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc_sd: vcc-sd {
		compatible = "regulator-fixed";
		regulator-name = "vcc_sd";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		regulator-always-on;
		regulator-boot-on;
		enable-active-low;
		gpio = <&gpio3 RK_PB1 GPIO_ACTIVE_LOW>;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc_1v8_wifi: vcc-1v8-wifi {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8_wifi";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-always-on;
		vin-supply = <&vcc5v0_sys>;
	};

	io-domains {
		compatible = "rockchip,rk3528-pmu-io-domain";
		vccio1-supply = <&vcc5v0_sys>;
		vccio2-supply = <&vcc5v0_sys>;
		vccio3-supply = <&vcc5v0_sys>;
		vccio4-supply = <&vcc_sd>;
		vccio5-supply = <&vcc_1v8_wifi>;
		vccio6-supply = <&vcc_sd>;
		vccio7-supply = <&vcc5v0_sys>;
		status = "okay";
	};

	/*
	 * Minimal syscon for GRF at ff300000. The 6.12 dtsi points rockchip,usbgrf
	 * to &vo_grf (ff360000), but USB2 PHY control registers are in the plain
	 * GRF at ff300000 (confirmed by 6.1 working DTS).
	 */
	usb_grf: syscon@ff300000 {
		compatible = "rockchip,rk3528-grf", "syscon";
		reg = <0x0 0xff300000 0x0 0x90000>;
	};
};

&sdhci {
	bus-width = <8>;
	non-removable;
	max-frequency = <200000000>;
	status = "okay";
};

&sdmmc {
	bus-width = <4>;
	cap-sd-highspeed;
	disable-wp;
	max-frequency = <150000000>;
	no-1-8-v;
	vmmc-supply = <&vcc_sd>;
	vqmmc-supply = <&vcc_sd>;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc_bus4 &sdmmc_clk &sdmmc_cmd &sdmmc_det>;
	status = "okay";
};

&gmac0 {
	phy-mode = "rmii";
	phy-handle = <&rmii0_phy>;
	clock_in_out = "input";
	status = "okay";
};

&mdio0 {
	rmii0_phy: ethernet-phy@2 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <2>;
		clocks = <&cru 0x122>;
		phy-is-integrated;
		resets = <&cru 0xb8>;
	};
};

/*
 * USB: u2phy-only, no combphy.
 * /delete-property/ power-domains avoids SError on PMU regmap access.
 * rockchip,usbgrf corrected from &vo_grf to &usb_grf (ff300000).
 */
&u2phy {
	/delete-property/ power-domains;
	/delete-property/ rockchip,usbgrf;
	rockchip,usbgrf = <&usb_grf>;
	status = "okay";
};

&u2phy_otg {
	vbus-supply = <&vcc5v0_host>;
	status = "okay";
};

&u2phy_host {
	phy-supply = <&vcc5v0_host>;
	status = "okay";
};

&usb_host0_xhci {
	/delete-property/ power-domains;
	dr_mode = "host";
	phys = <&u2phy_otg>;
	phy-names = "usb2-phy";
	maximum-speed = "high-speed";
	vbus-supply = <&vcc5v0_host>;
	snps,dis_u2_susphy_quirk;
	snps,usb2-lpm-disable;
	snps,dis-del-phy-power-chg-quirk;
	snps,tx-fifo-resize;
	status = "okay";
};

&usb_host0_ehci {
	/delete-property/ power-domains;
	phys = <&u2phy_host>;
	phy-names = "usb";
	status = "okay";
};

&usb_host0_ohci {
	/delete-property/ power-domains;
	phys = <&u2phy_host>;
	phy-names = "usb";
	status = "okay";
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0m0_xfer>;
	status = "okay";
};

&tsadc { status = "okay"; };

&threshold { temperature = <75000>; };
&target { temperature = <85000>; };
&soc_crit { temperature = <100000>; };

&pinctrl {
	usb {
		vcc5v0_host_en: vcc5v0-host-en {
			rockchip,pins = <4 RK_PC2 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};
};